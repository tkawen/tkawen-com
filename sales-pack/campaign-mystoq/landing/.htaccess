# Protect lead data + logs + secrets from public access.
<FilesMatch "\.(jsonl|log|secret|env)$">
  Require all denied
</FilesMatch>

# Block all dotfiles (.secret, .env, .htaccess itself, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Block progress / rate-limit state files
<FilesMatch "^\.progress|^\.rate-limit">
  Require all denied
</FilesMatch>

# Prevent directory listing.
Options -Indexes

# Default to index.php
DirectoryIndex index.php

# Cache nothing (personalised page).
<IfModule mod_headers.c>
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
</IfModule>
