sales-pack/lists/*.csv
sales-pack/lists/*.jsonl
sales-pack/lists/*.log

# Server-side extractor scripts contain hardcoded secret keys
sales-pack/tools/

# Per-campaign data + logs (PII: emails, phones, opens, leads)
